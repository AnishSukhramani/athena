# Hyperbrowser - required for job scraping (DentalPost, Indeed, LinkedIn, iHireDental, Jobley)
HYPERBROWSER_API_KEY=your_hyperbrowser_api_key

# OpenAI - required for Hyperbrowser page.extract (LLM-powered extraction)
OPENAI_API_KEY=your_openai_api_key

# Hunter.io - for lead enrichment (email/phone lookup). Skip initially if not set.
HUNTER_API_KEY=your_hunter_api_key

# Google Sheets - target sheet for leads
GOOGLE_SHEET_ID=your_spreadsheet_id_from_url
# Use one of:
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json
# GOOGLE_SERVICE_ACCOUNT_BASE64=<base64-encoded JSON of service account key>
