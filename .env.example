# --- JobPortalScout v0 (legacy) — pnpm run scout
HYPERBROWSER_API_KEY=
OPENAI_API_KEY=
HUNTER_API_KEY=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_BASE64=
GOOGLE_SERVICE_ACCOUNT_PATH=
LOG_LEVEL=info

# --- Opportunity Brain v1 — Supabase
# From Supabase dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Job Signal Engine
CAREER_DOMAIN_SEEDS=

# Review / Phone Friction (Google Places)
GOOGLE_MAPS_API_KEY=
REVIEW_PRACTICE_QUERIES=
REVIEW_DB_PRACTICE_LIMIT=15

# NPPES
NPPES_CSV_PATH=
NPPES_MAX_ROWS=5000

# Website scanner
WEBSITE_SCAN_LIMIT=20

# Tech stack (legacy PMS / portal detection)
TECH_STACK_SCAN_LIMIT=20
TECH_STACK_EXTRA_PATHS=
BUILTWITH_API_KEY=

# Meta Ad Library + LinkedIn x-ray (Hyperbrowser extract)
# Real page IDs / URLs: workers/config/competitor-pages.json or JSON in:
# COMPETITOR_FB_PAGES_JSON={"competitors":[{"key":"weave","name":"Weave","adLibraryUrl":"https://www.facebook.com/ads/library/..."}]}
COMPETITOR_FB_PAGES_JSON=
XRAY_LINKEDIN_POST_URLS=
XRAY_PRACTICE_MATCH_LIMIT=4000
LINKEDIN_HB_PROFILE_ID=

# Scoring
OPPORTUNITY_DAILY_CAP=50
OPENAI_MODEL=gpt-4o-mini

# Evidence (optional S3)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# --- Social publisher (Facebook / LinkedIn) — brain-web /api/social/*
# Page and profile tokens are stored in Supabase table social_accounts (manual seed or SQL); no OAuth in v1.
# Optional overrides (defaults are fine for most apps):
FACEBOOK_GRAPH_API_VERSION=v21.0
# LinkedIn REST version header (e.g. 202411). Used by lib/linkedin-publish.ts.
LINKEDIN_REST_VERSION=202411
